<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment android:id="@+id/homeFragment"
        android:name="com.unicundi.unimarket.ui.fragment.HomeFragment"
        android:label="Inicio">
        <action android:id="@+id/action_home_to_detalle"
            app:destination="@id/detalleProductoFragment"/>
    </fragment>

    <fragment android:id="@+id/mensajesFragment"
        android:name="com.unicundi.unimarket.ui.fragment.MensajesFragment"
        android:label="Mensajes">
        <action android:id="@+id/action_mensajes_to_chat" app:destination="@id/chatFragment"/>
    </fragment>

    <fragment android:id="@+id/perfilFragment"
        android:name="com.unicundi.unimarket.ui.fragment.PerfilFragment"
        android:label="Perfil">
        <action android:id="@+id/action_perfil_to_editar"
            app:destination="@id/editarPerfilFragment"/>
        <action android:id="@+id/action_perfil_to_detalle"
            app:destination="@id/detalleProductoFragment"/>
    </fragment>

    <fragment android:id="@+id/publicarFragment"
        android:name="com.unicundi.unimarket.ui.fragment.PublicarFragment"
        android:label="Publicar"/>

    <fragment android:id="@+id/detalleProductoFragment"
        android:name="com.unicundi.unimarket.ui.fragment.DetalleProductoFragment"
        android:label="Detalle">
        <action android:id="@+id/action_detalle_to_chat" app:destination="@id/chatFragment"/>
        <action android:id="@+id/action_detalle_to_perfilPublico" app:destination="@id/perfilPublicoFragment"/>
    </fragment>

    <fragment android:id="@+id/misPublicacionesFragment"
        android:name="com.unicundi.unimarket.ui.fragment.MisPublicacionesFragment"
        android:label="Mis Publicaciones">
        <action android:id="@+id/action_misPublicaciones_to_detalle"
            app:destination="@id/detalleProductoFragment"/>
    </fragment>

    <fragment android:id="@+id/favoritosFragment"
        android:name="com.unicundi.unimarket.ui.fragment.FavoritosFragment"
        android:label="Favoritos">
        <action android:id="@+id/action_favoritos_to_detalle"
            app:destination="@id/detalleProductoFragment"/>
    </fragment>

    <fragment android:id="@+id/ayudaFragment"
        android:name="com.unicundi.unimarket.ui.fragment.AyudaFragment"
        android:label="Ayuda"/>


    <fragment android:id="@+id/chatFragment"
        android:name="com.unicundi.unimarket.ui.fragment.ChatFragment"
        android:label="Chat">
        <argument android:name="nombreVendedor" android:defaultValue="Vendedor" app:argType="string"/>
        <argument android:name="tituloProducto" android:defaultValue="Producto" app:argType="string"/>
        <action android:id="@+id/action_chat_to_perfilPublico" app:destination="@id/perfilPublicoFragment"/>
    </fragment>

    <fragment android:id="@+id/perfilPublicoFragment"
        android:name="com.unicundi.unimarket.ui.fragment.PerfilPublicoFragment"
        android:label="Perfil">
        <action android:id="@+id/action_perfilPublico_to_chat" app:destination="@id/chatFragment"/>
        <action android:id="@+id/action_perfilPublico_to_detalle" app:destination="@id/detalleProductoFragment"/>
    </fragment>

    <fragment android:id="@+id/editarPerfilFragment"
        android:name="com.unicundi.unimarket.ui.fragment.EditarPerfilFragment"
        android:label="Editar Perfil"/>

</navigation>
