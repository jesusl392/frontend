<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_gris">

    <!-- Contenido principal con scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:background="@color/primario">

                <!-- Botón abrir drawer -->
                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_menu_hamburger"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Menu"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/txtTituloHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="UniMarket"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanco"/>
            </LinearLayout>

            <!-- Barra de búsqueda + botón filtro -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@color/blanco">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_busqueda"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp">

                    <EditText
                        android:id="@+id/etBuscar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="Que estas buscando hoy?"
                        android:textSize="14sp"
                        android:textColor="@color/texto_primario"
                        android:textColorHint="@color/gris_icono"
                        android:imeOptions="actionSearch"
                        android:inputType="text"/>
                </LinearLayout>

                <!-- Botón filtros -->
                <ImageButton
                    android:id="@+id/btnFiltros"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:background="@drawable/bg_btn_filtro_simple"
                    android:contentDescription="Filtros"
                    android:padding="12dp"/>
            </LinearLayout>

            <!-- Categorías chips -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false"/>

            <!-- Card Destacado -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDestacado"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/verde_medio">

                    <ImageView
                        android:id="@+id/imgDestacado"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#88000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Destacado"
                        android:textSize="12sp"
                        android:textColor="@color/blanco"
                        android:background="@drawable/bg_badge_destacado"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_margin="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="bottom"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/txtDestacadoTitulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Producto Destacado"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/blanco"/>

                        <TextView
                            android:id="@+id/txtDestacadoPrecio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="15sp"
                            android:textColor="@color/blanco"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Banner vende rápido -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/blanco">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vende rapido"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/texto_primario"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sube tus articulos en menos de 2 minutos y llega a toda la comunidad."
                        android:textSize="13sp"
                        android:textColor="@color/texto_secundario"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnEmpezarAhora"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Empezar ahora"
                        android:backgroundTint="@color/texto_primario"
                        android:textColor="@color/blanco"
                        android:textSize="14sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Novedades -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Novedades en el campus"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/texto_primario"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp"/>

            <ProgressBar
                android:id="@+id/progressHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerProductos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="90dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Panel de filtros encima del contenido (se despliega desde arriba) -->
    <include
        android:id="@+id/includeFiltros"
        layout="@layout/layout_filtros_panel"/>

</FrameLayout>
