<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="100dp" android:layout_height="100dp"
    android:layout_marginEnd="10dp">
    <ImageView android:id="@+id/imgMiPublicacion"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="#F0F0F0" android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"/>
    <TextView android:id="@+id/txtEstadoPublicacion"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="top|start" android:layout_margin="6dp"
        android:text="Activo" android:textSize="10sp" android:textColor="#FFFFFF"
        android:paddingStart="6dp" android:paddingEnd="6dp"
        android:paddingTop="2dp" android:paddingBottom="2dp"
        android:backgroundTint="#00897B"/>
</FrameLayout>
