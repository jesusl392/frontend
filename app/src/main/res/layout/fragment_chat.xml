<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo_gris">

    <!-- Header del chat -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/verde_principal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnVolverChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:layout_marginEnd="10dp"
            android:tint="@color/blanco"/>

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:id="@+id/imgAvatarChatHeader"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_avatar_small"
                android:src="@android:drawable/ic_menu_gallery"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:id="@+id/txtNombreChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Vendedor"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/blanco"/>
            <TextView
                android:id="@+id/txtProductoChat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sobre: Producto"
                android:textSize="12sp"
                android:textColor="#AADDAA"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Preview del producto (visible solo al entrar desde un producto) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardProductoPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/blanco">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgProductoPreview"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:background="#F0F0F0"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sobre este producto:"
                    android:textSize="11sp"
                    android:textColor="@color/texto_secundario"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/txtProductoPreviewTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/texto_primario"
                    android:maxLines="2"
                    android:ellipsize="end"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Mensajes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"/>

    <!-- Input mensaje -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blanco"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginEnd="8dp">
            <EditText
                android:id="@+id/etMensaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Escribe un mensaje..."
                android:textSize="14sp"
                android:textColor="@color/texto_primario"
                android:textColorHint="@color/gris_icono"
                android:inputType="textMultiLine"
                android:maxLines="3"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEnviar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/bg_btn_enviar"
            android:contentDescription="Enviar"
            android:padding="12dp"/>
    </LinearLayout>

</LinearLayout>
